{
  agents: {
    defaults: {
      model: {
        primary: "openai-codex/gpt-5.4",
        fallbacks: ["github-copilot/gpt-5-mini"],
      },
      models: {
        "openai-codex/gpt-5.4": { alias: "quality_draft" },
        "github-copilot/gpt-5-mini": { alias: "cheap_fast" },
        "openai-codex/gpt-5.4-browser": { alias: "browser_agent" },
      },
    },
    "lead-enrichment": {
      description: "Summarize raw lead signals, classify website state, and recommend a primary service lane.",
    },
    "contact-discovery": {
      description: "Extract public business contact points from websites and directory pages.",
    },
    "site-audit": {
      description: "Audit weak websites and produce a compact evidence pack for outreach.",
    },
    "draft-email": {
      description: "Create short plain-text outreach email drafts from evidence packs only.",
    },
    "draft-whatsapp": {
      description: "Create approved-template-aligned WhatsApp openers and permitted follow-up suggestions.",
    },
    "reply-classifier": {
      description: "Classify inbound replies and recommend next CRM actions.",
    },
  },
}

